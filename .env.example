# Copy to .env.local and adjust to point the app at different backends
# (e.g. a self-hosted wger instance or a staging mirror). All values are
# optional — src/config.ts falls back to the public production services.
#
# IMPORTANT: this is a static app. Vite bakes VITE_* values into the shipped
# JS bundle at build time, so never put secrets here. The Spoonacular API key
# is entered by the user at runtime (Settings → Nutrition) for that reason.

# wger exercise database
#VITE_WGER_API_BASE=https://wger.de/api/v2
#VITE_WGER_SITE_BASE=https://wger.de

# Open Food Facts
#VITE_OFF_SEARCH_URL=https://world.openfoodfacts.org/cgi/search.pl
#VITE_OFF_PRODUCT_BASE=https://world.openfoodfacts.org/api/v2/product

# TheMealDB
#VITE_MEALDB_API_BASE=https://www.themealdb.com/api/json/v1/1

# Spoonacular (base URL only — the key is a runtime user setting)
#VITE_SPOONACULAR_API_BASE=https://api.spoonacular.com
